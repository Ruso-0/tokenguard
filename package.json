{
  "name": "@ruso-0/nreki",
  "version": "6.0.2",
  "description": "MCP server that validates AI agent edits in RAM before they reach disk. Cross-file semantic checks via TypeScript Compiler API. Auto-fixes structural errors. Zero cloud dependencies.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "nreki": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/download-wasm.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "nreki",
    "mcp",
    "claude-code",
    "ai-safety",
    "ast-validation",
    "semantic-verification",
    "acid-transactions",
    "vfs",
    "typescript-compiler",
    "circuit-breaker",
    "tree-sitter",
    "pagerank",
    "blast-radius",
    "code-safety",
    "surgical-edit",
    "auto-healing",
    "zero-token",
    "codefix"
  ],
  "author": "Jherson Eddie Tintaya Holguin (https://github.com/Ruso-0)",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chokidar": "^4.0.3",
    "picomatch": "^4.0.3",
    "sql.js": "^1.12.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7",
    "typescript": "^5.9.3",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/picomatch": "^4.0.2",
    "tsx": "^4.19.3",
    "vitest": "^3.0.7"
  },
  "files": [
    "dist/",
    "wasm/",
    "scripts/download-wasm.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ruso-0/nreki"
  }
}
