{
  "name": "@ruso-0/nreki",
  "version": "8.0.1",
  "description": "MCP plugin that validates AI agent edits in RAM before they touch disk. Spectral clustering, architecture diffs, bridge detection, dead code oracle, and cross-file semantic checks for TypeScript, Go (gopls), and Python (pyright). Zero cloud dependencies.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "nreki": "bin/nreki.cjs"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/download-wasm.js",
    "lint": "tsc --noEmit",
    "benchmark:spectral": "tsx tests/benchmark-spectral.ts",
    "benchmark:external": "tsx tests/benchmark-spectral-external.ts",
    "benchmark:precision": "tsx tests/benchmark-precision.ts"
  },
  "keywords": [
    "nreki",
    "mcp",
    "claude-code",
    "cursor",
    "copilot",
    "ai-safety",
    "ai-coding-agent",
    "ast-validation",
    "semantic-verification",
    "acid-transactions",
    "vfs",
    "typescript-compiler",
    "gopls",
    "pyright",
    "multi-language",
    "circuit-breaker",
    "tree-sitter",
    "pagerank",
    "blast-radius",
    "code-safety",
    "surgical-edit",
    "auto-healing",
    "type-regression",
    "spectral-topology",
    "fiedler-vector",
    "topology-aware-rag",
    "lsp-sidecar",
    "spectral-clustering",
    "architecture-diff",
    "bridge-detection",
    "dead-code-oracle",
    "cyclomatic-complexity",
    "union-find"
  ],
  "author": "Jherson Eddie Tintaya Holguin (https://github.com/Ruso-0)",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chokidar": "^4.0.3",
    "picomatch": "^4.0.3",
    "sql.js": "^1.12.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "typescript": ">=5.5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": false
    }
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/picomatch": "^4.0.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "files": [
    "bin/",
    "dist/",
    "wasm/",
    "templates/",
    "scripts/download-wasm.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ruso-0/nreki"
  }
}
